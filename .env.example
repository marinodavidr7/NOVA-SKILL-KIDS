# ==========================================
# CONFIGURACIÓN DE ENTORNO LOCAL
# ==========================================
# 1. Copia este archivo y renómbralo a ".env"
# 2. Modifica "root:root" por tu usuario y contraseña de MySQL.
# 3. Guarda el archivo y ejecuta en la terminal: npm run db:setup
#    (Esto creará la base de datos automáticamente si no existe)

DATABASE_URL="mysql://root:root@127.0.0.1:3306/estancia"
